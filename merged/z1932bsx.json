{"ark":"ark:/21198/z1932bsx","reconstruction":false,"type":{"id":"manuscript","label":"Manuscript"},"shelfmark":"Sinai Syriac 192","extent":"207 ff.","weight":"1762.5 g","dim":"272 x 196 x 76 mm","state":{"id":"codex","label":"Codex"},"part":[{"label":"Part 1","support":[{"id":"paper","label":"Paper"}],"layer":[{"ark":"ark:/21198/s1v63n","reconstruction":false,"state":{"id":"overtext","label":"Overtext"},"label":"Sinai Syriac 192, Overtext (Melkite)","writing":[{"script":[{"id":"melkite","label":"Melkite","writing_system":"Syriac"}]}],"text_unit":[{"ark":"ark:/21198/s1nt0v","reconstruction":false,"label":"Typikon","lang":[{"id":"class1252","label":"Syriac"}],"work_wit":[{"work":{"ark":"ark:/21198/s1qk5z","pref_title":"Typikon","alt_title":["Typikon"],"genre":[{"id":"liturgical-texts","label":"Liturgical texts"}],"rel_con":[],"refno":[],"bib":[]},"locus":"ff. 2r-249v"}],"parent":["ark:/21198/s1v63n"]}],"para":[{"type":{"id":"colophon","label":"Colophon"},"locus":"249r-249v","lang":[{"id":"class1252","label":"Syriac"}],"as_written":"ܢܣܒ ܚܬܡܐ ܕܟܬܒܐ ܗܢܐ ܩܕܝܫܐ ܕܩ̈ܢܘܢܐ ܕܝܘܡܬܐ ܫܚ̈ܝܡܐ ܕܬܡ̈ܢܝܐ ܪ̈ܟܢܐ : ܕܬܝܒܘܬܐ ܘܠܡ̈ܐܠܟܐ: ܘܠܡܪܝ ܝܘܚܢܢ ܘܠܝܠܕܬ ܐܠܗܐ ܘܠܫ̈ܠܝܚܐ ܘܠܨܠܝܒܘܬܐ ܘܠܣ̈ܗܕܐ ܡܥ̈ܢܝܕܐ: ܐܫܬܡܠܝ ܕܝܢ ܒܐܝ̈ܕܝ ܐܢܫ: ܡܚܝܠܐ ܘܚ̇ܛܝܐ ܘܡܦܠܦ... ܒܣ̈ܢܝܬܐ ܐܒܪܗܡ ܩܫܝܫܐ ܒܫܡܐ ܘܠܐܒܥ̇ܒܕܐ: ܒܪܕܘܝܕܐ ܫܬܡܠܝ ܕܝܢ ܝܘܡ ܥܪܘܒܬܐ ܒܬܫܪ̈ܝܢ ܩܕܡܝܐ: ܬܒܫ̄ܥ ܫ̈ܥܝܢ ܕܝܠܗ̣ ܕܝܘܡܐ: ܫܢܬ ܐܠܦ ܘܚܡܫ̈ܡܐܐ ܘܚܡܫ̈ܝܢ ܘܗ̄: ܡܢ ܫ̈ܢܝܐ ܕܐܠܟܣܢܕܪܘܣ ܒܪ ܦܝܠܝܦܘܣ ܡܩܕܘܢܐ ܐܬܟܬܒ ܒܩܪܝܬܐ ܡܒܪܟܬܐ ܕܚܡܬ ܠܡܫ̄ܝ̣ ܕܐܪܫܡ ܓܕܝܢ ܡܢ ܐܬܪܐ ܕܛܪܦܠܘܣ ܡܕܝܢܬܐ ܒܥܕܬܐ ܕܚܣܝܐ ܡܪܝ ܐܣܝܐ ܨܠܘܬܗ ܫܘܪܐ ܬܗܘܐ ܠܢ ܠܥܡܠ: ܘܐܠܗܐ ܐܒܐ ܕܟܠ ܪ̈ܚܡܐ: ܢܚܣܐ ܠܟܬܘܒܢܐ ܘܠܩܪ̈ܘܝܐ ܘܠܟܠ ܡܢ ܕܐܝܬܠܗ̣ ܫܘܬܦ̄ܘ ܒܟܬܒܐ ܗܢܐ܀ ܐܡܝܢ ܐܡܝܢ܀","assoc_name":[{"value":"Abraham bar Dawid","as_written":"ܐܒܪܗܡ ܒܪ ܕܘܝܕ","role":{"id":"scribe","label":"Scribe"}}]}],"assoc_date":[{"value":"1243 CE","iso":{"not_before":"1243"},"type":{"id":"origin","label":"Date of Origin"}}],"features":[{"id":"dated","label":"Dated"},{"id":"deco-geometric","label":"Decoration, Geometric"},{"id":"deco-vegetative","label":"Decoration, Vegetative"},{"id":"he