                      "alt_title": "Book of Hours for the period of the Nativity, Epiphany, and Good Friday",
                      "as_written": "كتبة سواعى بزمونى الميلاد وبزمونى الغطاس والجمعه الكبيره (f. 147v)",
                      "locus": "ff. 2r-147v",
                      "excerpt": [
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 2r",
                          "as_written": "الساعة الاوَلة. تقول قدَوس الله وَما يتلوَها",
                          "translation": [
                            "The First Hour: Say, “Most Holy God…” and what follows next"
                          ]
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 147r",
                          "as_written": "وَالسبح لله دايماً وَعلينا رحمته امين",
                          "translation": [
                            "And glory to God, and His mercy upon us. Amen"
                          ]
                        }
                      ],
                      "note": [
                        "Further subdivided with rubrics for the various hours and includes readings from the Psalms and other prayers"
                      ]
                    },
