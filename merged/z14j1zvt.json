                      "as_written": "اقوال لابينا القديس مار افرام السرياني (f. 6r) (fihrist)",
                      "locus": "ff. 173r-198v",
                      "excerpt": [
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 173r",
                          "as_written": "اول خراب نفس الراهب هو الضحك والباريسيا",
                          "translation": [
                            "The first ruin of the soul of a monk is laughter and parrēsia (παρρησία)…"
                          ]
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 198v",
                          "as_written": "وبتواضع العقل ارتفع شان العشار الذّي معه يوهلنا الرّب الحظ الذي لا يبلي مع كافة الصديقين فان به يليق المجد الى أباد الدهور امين",
                          "translation": [
                            "[...] and with humility of mind, the character of the publican is exalted with whom the Lord grants us his fate with all the saints, for the glory is worthy of him to the end of the ages. Amen"
                          ]
                        }
                      ],
                      "contents": [
                        {
                          "label": "Mimar of St. Ephrem that a monk ought not laugh or rejoice, bur rather weep and mourn for himself always, f. 173r"
                        },
                        {
                          "label": "Another by the same on love, repentance, and worldliness, f. 177r"
                        },
                        {
                          "label": "Another by the same on virginity, f. 180r"
                        },
                        {
                          "label": "Another by the same, a sermon on how one should not leave a place before putting on the holy habit, f. 187v"
                        },
                        {
                          "label": "Another by the same concerning the differences of lethargy, f. 190r"
                        },
                        {
                          "label": "Another by the same, treatise on the destruction of pride, f. 192v"
                        }
                      ]
