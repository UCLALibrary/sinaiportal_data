                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 2r",
                          "as_written": "نبتدي بعَون الله و حُسن توفيقه و ارشاده و تسديده. نكتب الاربعة الأناجيل المقدّسة. الاوّل من ذلك بشارة القديس متّی الإنجيلي"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 49v",
                          "as_written": "كمل نسخ بشارة الرَسول العظيم متی الإنجيلي و لله السبح و المجد دايماً و علينا رحمته امين"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 50v",
                          "as_written": "كملت الاصحاحات و عددها و السبح لرب المجد دايماً سرمداً و علينا رحمته امي"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 51ar",
                          "as_written": "؛ فاتحة بشارة الرّسول المُعظّم مرقس الإنجيلي الطّاهر البشير"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 78v",
                          "as_written": "كمل إنجيل القدّيس مرقس البشير الّذي كتبه برومية في عهد بطرس الرّسول و المجد لله دائماً ابدا"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 79v",
                          "as_written": "؛ نبتدي بعَون الله و حُسن توفيقه و ارشاده و تسديده نكتب بشارة القدّيس لوقا الإنجيلي"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 125r",
                          "as_written": " و السّبح لله دايماً و علينا رحمته آمين"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 126v",
                          "as_written": "تمّت الاصحاحات الّتي الإنجيل لوقا القدّيس البشير الإنجيلي ترحمنا[؟] الرّب لشفاعته آمين"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 127r",
                          "as_written": "؛ إبتدا بشارة القدّيس يوحنّا الإنجيلي"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 163r",
                          "as_written": "كملت هذه النّسخة المقدّسة بحبل الله المقدّس طور سينا"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 164r",
                          "as_written": "؛ نبتدي بعَون الله نكتب فصول الأناجيل الّتي يقروا في طَول الخمسين"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 193r",
                          "as_written": "كمل بعون الله و رحمته کتبة السّنكسار"
                        }
                      ]
                    }
