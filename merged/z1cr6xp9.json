              {
                "type": {
                  "id": "history",
                  "label": "History"
                },
                "locus": "ff. 300r-300v",
                "lang": [
                  {
                    "id": "arab1395",
                    "label": "Arabic"
                  }
                ],
                "as_written": "فرغ من نسخة الراهب الحقير أنطوني في دير القديس ماري سابا يوم الخميس لعشرين يوم مضت من تشرين الأول التاريخ الثالث عشر سنة ستة الاف وستمائه وثمانية وخمسين سنة للعالم وهو الراهب الحقير انطوني بن القس جرجس الخوري الزبداني غفر الله له ولوالديه ولجميع اخوته بشفاعة  السيدة أم النور الطاهرة البثول والقديس ماري سابا وجميع القديسين آمين آمين آمين / أوقفه عن روحه على كنيسة دير السيق فوق وأسفل يا خير مطلوب وأكرم طالب اغفر لصاحبه نعم والكاتب  يا قارئ صلى الكوتئيب الحقير وسامحه في الغلط والزلل بغفر الله لك وجميع بنى المعمودية  الارثذكسية والسبح لله دائما وعلينا رحمته آمين",
                "assoc_place": [
