                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 2r",
                          "as_written": "نبتدي بعون الله سبحانه نكتب الإنجيل المقدّس"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 53v",
                          "as_written": "؛ نبتدي بعون الله و حسن توفيقه نكتب بشارة الرّسول مرقص الإنجيلي"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 81v",
                          "as_written": "كمل … بشارة المرقص الإنجيلي الّذي كتبهُ في رومية علی[؟] عهد بطرس الرّسول"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 82r",
                          "as_written": "؛ نبتدي بعون الله سبحانه و تعالیٰ نكتب الإنجيل المقدّس من بشارة الرّسول لوقا الإنجيلي"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 128v",
                          "as_written": "؛ نبتدي بعون الله سبحانه نكتب إنجيل يوحنّا"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 165r",
                          "as_written": "كمل … بشارة المرسول الإنجيلي يوحنّا الفاضل، المتکلّم بالاهيّات، المحبوب من الرّب، و بتمامها. كمل نسخة الإنجيل المقدّس"
                        },
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 166r",
                          "as_written": "؛ نبتدي بعون الله سبحانه نكتب فصول الأناجيل"
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 192v",
                          "as_written": "كمل … نسخة فهرسة و سنكنساري الإنجيل المقدّس"
                        }
                      ]
                    }
