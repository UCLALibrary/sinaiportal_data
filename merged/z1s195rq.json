                    {
                      "work": {
                        "desc_title": "Thalassius Abbas, Centuriae iv de caritate et continentia",
                        "genre": [
                          {
                            "id": "historical-works",
                            "label": "Historical works"
                          }
                        ]
                      },
                      "locus": "ff. 57r-79v",
                      "excerpt": [
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 57r",
                          "as_written": "لاخي الحبيب بولص مولايي من تلاسيوس الصامت في حاله الطاهر",
                          "translation": [
                            "To my beloved brother Paul, my lord, from Thalassius the silent in his pure state…"
                          ]
                        },
                        {
                          "type": {
                            "id": "explicit",
                            "label": "Explicit"
                          },
                          "locus": "f. 79v",
                          "as_written": "انهُما من قبل كُل زمانٍ و دهر وقبل وفوق الزمان والدهر اذ بهُما كل دهرٍ وزمان والبرايا التي في الدهر والتي في الزمان ومن جهة انهُما ازليّان مع الاب على ما قدمنا ذكره فلهُما معه المجد والعز الى اباد الدهور كلها امين",
                          "translation": [
                            "They are before every time and eternity, both before and above time and eternity, since all time and eternity are in them and creation which is in eternity and which is in time, yet they are eternal with the Father, as we have mentioned, to Whom with the Father is the glory and power to the end of the ages. Amen"
                          ]
                        }
                      ],
                      "contents": [
                        {
                          "label": "First Century, f. 57r"
                        },
                        {
                          "label": "Second Century, f. 62r"
                        },
                        {
                          "label": "Third Century, f. 67r"
                        },
                        {
                          "label": "Fourth Century, f. 72v"
                        }
                      ],
                      "note": [
                        "بولص القس, Paul the priest [letter recipient], f. 57r"
                      ]
