                      "alt_title": "The Gospel of Bartholomew and Andrew ",
                      "as_written": "هذا بشارة التلميذيْن برثولوماوس واندراوس تلاميذ السيد المسيح (f. 1r)",
                      "locus": "ff. 1r-28v",
                      "excerpt": [
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 1r",
                          "as_written": "كان بعد قيامة ربنا ايسوع المسيح من بين الأموات"
                        },
                        {
                          "type": {
                            "id": "subscription",
                            "label": "Subscription"
                          },
                          "locus": "f. 28v",
                          "as_written": "وثبتوهم على الأمانة المستقينة باسم الرب ايسوع المسيح وخرجوا من عندهم وهم سبحوا الله"
                        }
                      ]
                    },
                    {
                      "work": {
                        "desc_title": "Miracles of Elias",
                        "genre": [
                          {
                            "id": "hagiographies",
                            "label": "Hagiographies"
                          }
                        ]
                      },
                      "as_written": "عجيبة مر الياس وما صنع مع الصبي خادم كنيسة الاسقف الذي في جبل عوف (f. 29r)",
                      "locus": "ff. 28v-40r",
                      "excerpt": [
                        {
                          "type": {
                            "id": "incipit",
                            "label": "Incipit"
                          },
                          "locus": "f. 29r",
                          "as_written": "كان في ذلك زمان على أيام ملكوك المسيحين قبل ظهورالاسلام رجل صالح من الاستبا نصراني"
