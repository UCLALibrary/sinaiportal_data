                ],
                "as_written": "وكان فراغ نسخة يوم السبت الحادي عشر من شوال سنة ثلث وثلثين وخمس مائه رحم الله من قرأ وسمع ودعا الكاتبة بالرحمة والمغفرة آمين رب العالمين والشكر لله دائما ",
                "assoc_date": [
                  {
                    "value": "1139 CE",
                    "iso": {
