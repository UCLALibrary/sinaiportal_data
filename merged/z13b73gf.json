                    ]
                  }
                ]
              },
              {
                "type": {
                  "id": "history",
                  "label": "History"
                },
                "locus": "f. 193v",
                "lang": [
                  {
                    "id": "arab1395",
                    "label": "Arabic"
                  }
                ],
                "as_written": "وكان فراغ ذلك يوم الثلاثاء النصف وربيع الأول سنة اثنين وثلثين وخمسمائه  رحم الله من قرأ ودعا الكاتب قسطة بشفاعة السيدة الطاهرة والقديسين بربارة ويوليانى وجميع القديسين آمين ",
                "assoc_date": [
