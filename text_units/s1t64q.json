      "locus": "ff. 3v-211r",
      "excerpt": [
        {
          "type": {
            "id": "incipit",
            "label": "Incipit"
          },
          "locus": "f. 2r",
          "as_written": "نبديَ بعون الله و حُسن توفيقه بكتابة فهرسة اصحاحات البشارة المقدّسة الّتي قالها الرّوح القدس علیٰ فمّ متثیٰ \n "
        },
        {
          "type": {
            "id": "explicit",
            "label": "Explicit"
          },
          "locus": "f. 3r",
          "as_written": "هي[؟] الفهرسة المباركة و لله المنّة[؟] و الشّكر آمين"
        },
        {
          "type": {
            "id": "incipit",
            "label": "Incipit"
          },
          "locus": "f. 3v",
          "as_written": "؛ فاتحة بشارة متثَیٰ الإنجيلي"
        },
        {
          "type": {
            "id": "explicit",
            "label": "Explicit"
          },
          "locus": "f. 65r",
          "as_written": "كمل نسخ بشارة الرّسول العظيم مثّیٰ الإنجيلي و لله السّبح و المجد و الاكرام دايماً ابداً آمين "
        },
        {
          "type": {
            "id": "incipit",
            "label": "Incipit"
          },
          "locus": "f. 66v",
          "as_written": "؛ فاتحة بشارَة الرّسُول المُعظّم مرقص الإنجيلي بَطْريرَك الإسكندرية"
        },
        {
          "type": {
            "id": "incipit",
            "label": "Incipit"
          },
          "locus": "f. 104v",
          "as_written": "؛ نبدِءُ بعون الله و حُسن توفيقه ننقل انجيل لُوقا البشير من اللَّسان اليُوناني إلي العَربي"
        },
        {
          "type": {
            "id": "explicit",
            "label": "Explicit"
          },
          "locus": "f. 105v",
          "as_written": "تمّت الفهرسة و المجد دايماً لرَبُّ المَجدُ \n"
        },
        {
          "type": {
            "id": "incipit",
            "label": "Incipit"
          },
          "locus": "f. 106v",
          "as_written": "؛ فاتحة إنجيل الرّسُول النّبيل المُعظّم لُوقا الإنجيلي أحد الرّسل السّبعين"
        },
        {
          "type": {
            "id": "explicit",
            "label": "Explicit"
          },
          "locus": "f. 167r",
          "as_written": "كُمِلت فهرسة الإصحاحات و المجدُ لله دائماً أبداً آمين"
        },
        {
          "type": {
            "id": "incipit",
            "label": "Incipit"
          },
          "locus": "f. 167v",
          "as_written": "؛ فاتحة إنجيل الرَّسُول العظيم يُوحنّا الثاولوغُس أَحد الرّسُل الأثنا عَشر"
        },
        {
          "type": {
            "id": "explicit",
            "label": "Explicit"
          },
          "locus": "f. 211r",
          "as_written": "و كان الفراغ من نَسخُه "
        }
      ]
    }
  ],
