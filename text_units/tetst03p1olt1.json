                    "type": {
                        "id": "incipit",
                        "label": "Incipit"
                    },
                    "locus": "f. 1v",
                    "as_written": "في أول يوم من شهر أيلول تذكار القديس سمعان عمود النساك",
                    "translation": [
                        "On the first day of the month of Elul, commemoration of Saint Simeon, Pillar of the Ascetics"
                    ]
